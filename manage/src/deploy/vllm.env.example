# ohjime vLLM model server configuration.
# Installed to /etc/ohjime/vllm.env (install.sh will not overwrite an existing
# file). After editing:  sudo systemctl restart ohjime-vllm

# Model id as published on Hugging Face. Qwen3-8B-AWQ is the pick for an 11 GB
# Turing card (RTX 2080 Ti, SM 7.5): ~5.5 GB of 4-bit weights leaves ample room
# for a 16K KV cache, and it needs no kernels newer than SM 7.5 supports.
VLLM_MODEL=Qwen/Qwen3-8B-AWQ

VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_MAX_LEN=16384
VLLM_GPU_UTIL=0.85

# --dtype float16   Turing has no bfloat16 support; float16 is required.
# --enforce-eager   Skips CUDA-graph capture: saves VRAM headroom on an 11 GB
#                   card at some decode-throughput cost. Drop it if you have
#                   memory to spare on a bigger GPU.
#
# Summarization needs no tool calling. If you extend the agent with tools, add:
#   --enable-auto-tool-choice --tool-call-parser hermes
VLLM_EXTRA=--dtype float16 --enforce-eager
