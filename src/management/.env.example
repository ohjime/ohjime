# Copy this file to `.env` and adjust as needed:  cp .env.example .env
#
# The values below match the vLLM server currently running on this machine
# (Qwen/Qwen3-8B-AWQ on port 8000). Confirm with:
#   curl http://localhost:8000/v1/models

# Local vLLM OpenAI-compatible endpoint. Keep the trailing /v1.
VLLM_API_BASE=http://localhost:8000/v1

# Model id EXACTLY as served by vLLM (the `id` field from /v1/models).
VLLM_MODEL=Qwen/Qwen3-8B-AWQ
# When running the Gemma 4 container instead (see docker/compose.yaml):
# VLLM_MODEL=google/gemma-4-E2B-it-qat-w4a16-ct

# vLLM ignores the API key unless it was started with --api-key.
# LiteLLM still requires a non-empty value, so leave this as-is.
VLLM_API_KEY=EMPTY

# Qwen3 is a hybrid reasoning model. Keep thinking OFF for fast, clean demo
# output; set to `true` to let the model emit <think> reasoning traces.
VLLM_ENABLE_THINKING=false
